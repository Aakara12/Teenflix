}
setHero(content[0]);
setInterval(rotateHero, 8000);

function renderContent(filteredContent = content) {
  const categories = [
    { title: "🔥 Trending Now", filter: c => c.categories.includes('trending') },
    { title: "🎬 Free Full Movies (Public Domain)", filter: c => c.type === 'movie' && c.source === 'Public Domain' },
    { title: "✨ Blender Open Movies", filter: c => c.source.includes('Blender') },
    { title: "📺 Popular Teen Series", filter: c => c.type === 'series' && c.year >= 2020 },
    { title: "🎞️ Classic Series", filter: c => c.type === 'series' && c.year < 2000 },
  ];
  
  const container = document.getElementById('content');
  container.innerHTML = '';
  
  categories.forEach(cat => {
    const items = filteredContent.filter(cat.filter);
    if (items.length === 0) return;
    
    const row = document.createElement('div');
    row.className = 'row';
    row.innerHTML = `
      <h2 class="row-title">${cat.title}</h2>
      <div class="row-posters">
        ${items.map(item => `
          <div class="poster" style="background-image: url('${item.img}')" onclick="openModal(content.find(c => c.id === ${item.id}))">
            <div class="poster-overlay">
              <div class="poster-title">${item.title}</div>
              <div class="poster-info">${item.match}% Match • ${item.year}</div>
              <div class="poster-buttons">
                <button class="icon-btn" onclick="event.stopPropagation(); playNow(content.find(c => c.id === ${item.id}))">▶</button>
                <button class="icon-btn" onclick="event.stopPropagation(); openModal(content.find(c => c.id === ${item.id}))">ℹ</button>
              </div>
            </div>
          </div>
        `).join('')}
      </div>
    `;
    container.appendChild(row);
  });
}

function openModal(item) {
  if (!item) return;
  // Show placeholder with big play button
  document.getElementById('playerContainer').innerHTML = `
    <div class="player-placeholder" onclick="playNow(content.find(c => c.id === ${item.id}))">
      <div class="play-big">▶</div>
      <div style="font-size:18px; font-weight:bold;">Click to Play</div>
      <div style="font-size:13px; margin-top:8px; color:#aaa;">${item.title}</div>
    </div>
  `;
  document.getElementById('modalTitle').textContent = item.title;
  document.getElementById('modalMeta').innerHTML = `
    <span class="match">${item.match}% Match</span>
    <span>${item.year}</span>
    <span style="border:1px solid #666; padding:0 6px;">${item.rating}</span>
    <span>${item.duration}</span>
  `;
  document.getElementById('modalDesc').textContent = item.desc;
  document.getElementById('modalTags').innerHTML = `Tags: <span>${item.tags.join(', ')}</span>`;
  document.getElementById('sourceInfo').innerHTML = `
    <strong>✓ ${item.source}</strong><br>
    ${item.source === 'Public Domain' ? 'This film is in the public domain — free to watch legally!' : 
      item.source.includes('Blender') ? 'Made with open-source software. Licensed under Creative Commons.' :
      'This is a trailer. Full episodes available on the listed platform.'}
  `;
  
  document.getElementById('modal').classList.add('active');
  document.body.style.overflow = 'hidden';
}

function playNow(item) {
  if (!item) return;
  document.getElementById('playerContainer').innerHTML = `
    <iframe src="https://www.youtube.com/embed/${item.videoId}?autoplay=1&rel=0" 
            allow="autoplay; encrypted-media; fullscreen" allowfullscreen></iframe>
  `;
  // Update source info
  document.getElementById('sourceInfo').innerHTML = `
    <strong>▶ Now Playing:</strong> ${item.title}<br>
    <strong>Source:</strong> ${item.source}
  `;
}

function playHero() {
  openModal(heroData);
  setTimeout(() => playNow(heroData), 100);
}

function closeModal() {
  document.getElementById('modal').classList.remove('active');
  document.getElementById('playerContainer').innerHTML = '';
  document.body.style.overflow = 'auto';
}

function searchContent() {
  const query = document.getElementById('searchInput').value.toLowerCase();
  if (query === '') { renderContent(); return; }
  const filtered = content.filter(c => 
    c.title.toLowerCase().includes(query) || 
    c.tags.some(t => t.toLowerCase().includes(query))
  );
  renderContent(filtered);
}

function filterCategory(cat, el) {
  document.querySelectorAll('.nav-links a').forEach(a => a.classList.remove('active'));
  if (el) el.classList.add('active');
  if (cat === 'all') { renderContent(); return; }
  const filtered = content.filter(c => c.categories.includes(cat) || c.type === cat);
  renderContent(filtered);
}

window.addEventListener('scroll', () => {
  document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 50);
});

document.getElementById('modal').addEventListener('click', (e) => {
  if (e.target.id === 'modal') closeModal();
});

document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape') closeModal();
});

renderContent();
</script>

</body>
</html>
